# ErrSight OSS — example environment.
# Copy to .env and fill in values that apply to your install.

# === Application ===
APP_HOST=errsight.local
# Generated with `bin/rails secret`. Required in production.
# SECRET_KEY_BASE=

# === Database ===
# Either set DATABASE_URL or use POSTGRES_* with the bundled docker-compose.yml.
DATABASE_URL=postgres://postgres:postgres@localhost:5433/errsight_community_development
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=errsight_community_development

# === Solid Queue ===
# Run the recurring scheduler + worker inside Puma (default). Set to false to
# run a separate `bin/jobs` process — recommended once you scale to multiple
# web replicas.
SOLID_QUEUE_IN_PUMA=true

# === Event retention ===
# Days to keep ingested events. Set to 0 to disable pruning entirely.
# The PruneEventsByRetentionJob runs daily at 4:15am — see config/recurring.yml.
RETENTION_DAYS=30

# === SMTP (transactional email) ===
# Required when :confirmable is enabled in app/models/user.rb. Use any
# standard SMTP provider — Mailgun, SendGrid, AWS SES, Postmark, Postfix,
# etc. If your install can't deliver email, remove :confirmable from the
# User model so users can register without verifying their address.
MAILER_FROM=no-reply@errsight.local
# Optional reply-to address. Defaults to MAILER_FROM if unset.
SUPPORT_EMAIL=
SMTP_ADDRESS=
SMTP_PORT=587
SMTP_DOMAIN=
SMTP_USERNAME=
SMTP_PASSWORD=

# === Optional: OAuth providers ===
# Either pair can be unset — only configured providers show a sign-in button.
# Email/password signup works regardless of OAuth state.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# === Access model: invite-only by default ===
# By default, ErrSight OSS disables public signup — only existing admins can
# invite new users via the in-product invitation flow. To re-enable open
# registration (small OSS communities, public dev groups), set this to "true".
# Invitees signing up via an invitation link register regardless of this
# setting; only the public /users/sign_up form is gated.
ALLOW_PUBLIC_SIGNUP=false

# === Bootstrap an admin user ===
# With invite-only mode (the default), this is the only way to create the
# first admin. `bin/rails db:seed` reads these vars and creates one admin +
# first organization. Leave blank to skip seeding — but then you'll need
# another path (rails console, or set ALLOW_PUBLIC_SIGNUP=true temporarily)
# to get the first user in.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=
ADMIN_ORG_NAME=

# === Optional: new-signup notifications ===
# When a new user registers, the app can email an operator. Defaults to
# one email per signup, sent to support@errsight.com. Override the
# recipient with ADMIN_NOTIFICATION_EMAIL. Set ADMIN_SIGNUP_NOTIFICATIONS
# to "disabled" to silence the email, or "digest" to short-circuit the
# per-signup callback (a daily roll-up job is left as future work).
ADMIN_NOTIFICATION_EMAIL=
ADMIN_SIGNUP_NOTIFICATIONS=

# === Optional: self-instrumentation ===
# Forward this app's own errors and log lines to itself (point ERRSIGHT_HOST
# at your install) or to any upstream ErrSight. Leave ERRSIGHT_API_KEY blank
# to disable.
ERRSIGHT_API_KEY=
ERRSIGHT_HOST=
