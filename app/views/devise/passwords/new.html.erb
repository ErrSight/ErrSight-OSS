<% content_for :title, "Reset password — ErrSight" %>

<div class="auth-panel">
  <div class="auth-head">
    <a href="/" class="auth-brand">
      <%= image_tag "errsight-wordmark-light.svg", alt: "ErrSight", class: "brand-logo", height: 40 %>
    </a>
    <h1 class="auth-title">Reset your password</h1>
    <p class="auth-subtitle">We'll send reset instructions to your email.</p>
  </div>

  <div class="auth-card">
    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "auth-form" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="auth-field">
        <%= f.label :email, "Email" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "auth-input", placeholder: "you@example.com" %>
      </div>

      <%= f.submit "Send reset instructions", class: "auth-submit" %>
    <% end %>

    <p class="auth-alt">
      <%= link_to "Back to sign in", new_user_session_path, class: "auth-link" %>
    </p>
  </div>
</div>
