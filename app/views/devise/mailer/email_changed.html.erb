<h1 style="margin:0 0 8px; font-size:22px; font-weight:600; color:#17161a; letter-spacing:-0.3px;">
  Your email address was changed
</h1>

<% if @resource.try(:unconfirmed_email?) %>
  <p style="margin:0 0 24px; font-size:15px; line-height:1.6; color:#5b5a5f;">
    Your ErrSight email is being changed to
    <strong style="color:#17161a;"><%= @resource.unconfirmed_email %></strong>.
    We've sent a confirmation link to the new address — the change takes effect once you follow it.
  </p>
<% else %>
  <p style="margin:0 0 24px; font-size:15px; line-height:1.6; color:#5b5a5f;">
    Your ErrSight email has been changed to
    <strong style="color:#17161a;"><%= @resource.email %></strong>.
  </p>
<% end %>

<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:#f6f5f1; border:1px solid #d9d7cf; border-radius:10px; margin:0 0 24px;">
  <tr>
    <td style="padding:18px 20px; font-size:13px; line-height:1.6; color:#5b5a5f;">
      If you didn't make this change, contact your organization's administrator right away.
    </td>
  </tr>
</table>
