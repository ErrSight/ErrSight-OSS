<h1 style="margin:0 0 8px; font-size:22px; font-weight:600; color:#17161a; letter-spacing:-0.3px;">
  Confirm your email
</h1>
<p style="margin:0 0 24px; font-size:15px; line-height:1.6; color:#5b5a5f;">
  Welcome to <span style="font-family: Georgia, 'Times New Roman', serif; font-style: italic; color:#ff5a3c; font-weight:400;">ErrSight</span>. Confirm <strong style="color:#17161a;"><%= @email %></strong> to activate your account.
</p>

<table role="presentation" cellpadding="0" cellspacing="0" border="0">
  <tr>
    <td style="border-radius:8px; background:#17161a;">
      <%= link_to "Confirm my account", confirmation_url(@resource, confirmation_token: @token), style: "display:inline-block; padding:12px 22px; color:#f6f5f1; text-decoration:none; font-size:14px; font-weight:600; letter-spacing:0.2px; border-radius:8px;" %>
    </td>
  </tr>
</table>

<p style="margin:24px 0 0; font-size:12px; color:#8f8d90; word-break:break-all;">
  If the button doesn't work, paste this link into your browser:<br>
  <%= confirmation_url(@resource, confirmation_token: @token) %>
</p>
