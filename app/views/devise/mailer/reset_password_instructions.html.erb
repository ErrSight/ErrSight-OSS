<h1 style="margin:0 0 8px; font-size:22px; font-weight:600; color:#17161a; letter-spacing:-0.3px;">
  Reset your password
</h1>
<p style="margin:0 0 24px; font-size:15px; line-height:1.6; color:#5b5a5f;">
  Someone requested a password reset for <strong style="color:#17161a;"><%= @resource.email %></strong>. Click the button below to choose a new one.
</p>

<table role="presentation" cellpadding="0" cellspacing="0" border="0">
  <tr>
    <td style="border-radius:8px; background:#17161a;">
      <%= link_to "Change my password", edit_password_url(@resource, reset_password_token: @token), style: "display:inline-block; padding:12px 22px; color:#f6f5f1; text-decoration:none; font-size:14px; font-weight:600; letter-spacing:0.2px; border-radius:8px;" %>
    </td>
  </tr>
</table>

<p style="margin:24px 0 0; font-size:13px; line-height:1.6; color:#5b5a5f;">
  If you didn't request this, you can safely ignore this email — your password won't change until you follow the link above and set a new one.
</p>

<p style="margin:16px 0 0; font-size:12px; color:#8f8d90; word-break:break-all;">
  If the button doesn't work, paste this link into your browser:<br>
  <%= edit_password_url(@resource, reset_password_token: @token) %>
</p>
