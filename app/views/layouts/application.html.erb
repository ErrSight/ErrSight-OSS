<!DOCTYPE html>
<html class="h-full" style="background:#f6f5f1">
  <head>
    <title><%= content_for(:title) || "Errsight" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Errsight">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="<%= asset_path("icon.png") %>" type="image/png">
    <link rel="icon" href="<%= asset_path("icon.svg") %>" type="image/svg+xml">
    <link rel="apple-touch-icon" href="<%= asset_path("icon.png") %>">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500;600;700&family=Geist:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "landing", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "design", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="design-body h-full antialiased" data-theme="light" data-density="comfortable">
    <% if user_signed_in? %>
      <% if impersonating? && true_admin %>
        <div style="background:#b45309; color:#fff; padding:8px 16px; text-align:center; font-family:var(--mono); font-size:12px; display:flex; justify-content:center; align-items:center; gap:12px;">
          <span>Impersonating <strong><%= current_user.email %></strong> as admin <strong><%= true_admin.email %></strong>.</span>
          <%= button_to "Return to admin", stop_impersonating_path, method: :delete,
                style: "background:#fff; color:#b45309; padding:2px 10px; border-radius:3px; border:none; cursor:pointer; font-family:inherit; font-size:inherit;" %>
        </div>
      <% end %>
      <div class="design-shell">
        <%= render "layouts/sidebar" %>
        <main class="main">
          <div id="flash-slot"><%= render "shared/flash" %></div>
          <%= yield %>
          <footer class="mt-20 pt-6" style="border-top: 1px solid var(--line); font-family: var(--mono); font-size: 11px; color: var(--fg-dimmer); display: flex; justify-content: center; gap: 20px;">
            <%= link_to "Support", support_path, style: "color: inherit;" %>
            <%= link_to "Privacy Policy", privacy_path, style: "color: inherit;" %>
            <%= link_to "Terms", terms_path, style: "color: inherit;" %>
          </footer>
        </main>
      </div>
    <% else %>
      <div id="flash-slot"><%= render "shared/flash" %></div>
      <main class="min-h-screen flex items-center justify-center">
        <%= yield %>
      </main>
    <% end %>
  </body>
</html>
