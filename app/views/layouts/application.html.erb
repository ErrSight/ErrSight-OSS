<!DOCTYPE html>
<html class="h-full" style="background:#f6f5f1">
  <head>
    <title><%= content_for(:title) || "Errsight" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Errsight">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="<%= asset_path("icon.png") %>" type="image/png">
    <link rel="icon" href="<%= asset_path("icon.svg") %>" type="image/svg+xml">
    <link rel="apple-touch-icon" href="<%= asset_path("icon.png") %>">
    <link rel="preload" href="<%= asset_path "Geist-Regular.woff2" %>" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="<%= asset_path "Geist-Medium.woff2" %>" as="font" type="font/woff2" crossorigin>
    <%= stylesheet_link_tag "fonts", "data-turbo-track": "reload" %>

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "landing", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "design", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="design-body h-full antialiased" data-theme="light" data-density="comfortable">
    <% if user_signed_in? %>
      <% if impersonating? && true_admin %>
        <div class="impersonation-bar">
          <span>Impersonating <strong><%= current_user.email %></strong> as admin <strong><%= true_admin.email %></strong>.</span>
          <%= button_to "Return to admin", stop_impersonating_path, method: :delete %>
        </div>
      <% end %>
      <div class="design-shell" data-controller="app-nav" data-action="keydown@window->app-nav#onKeydown">
        <header class="app-topbar">
          <button type="button" class="app-burger" data-app-nav-target="toggle" data-action="app-nav#toggle"
                  aria-expanded="false" aria-controls="appSidebar" aria-label="Open menu">
            <span class="app-burger-glyph"></span>
          </button>
          <%= link_to dashboard_path, class: "app-topbar-brand" do %>
            <%= image_tag "errsight-mark-onlight.svg", alt: "ErrSight", class: "mk" %>
            <span class="wm">Err<em>Sight</em></span>
          <% end %>
        </header>
        <div class="sidebar-backdrop" data-app-nav-target="backdrop" data-action="click->app-nav#close"></div>
        <%= render "layouts/sidebar" %>
        <main class="main">
          <div id="flash-slot"><%= render "shared/flash" %></div>
          <%= yield %>
          <footer class="app-footer mt-20 pt-6" style="border-top: 1px solid var(--line); font-family: var(--mono); font-size: 11px; color: var(--fg-dimmer); display: flex; justify-content: center; gap: 20px;">
            <%= link_to "Support", support_path, style: "color: inherit;" %>
            <%= link_to "Privacy Policy", privacy_path, style: "color: inherit;" %>
            <%= link_to "Terms", terms_path, style: "color: inherit;" %>
          </footer>
        </main>
      </div>
    <% else %>
      <div id="flash-slot"><%= render "shared/flash" %></div>
      <main class="min-h-screen flex items-center justify-center">
        <%= yield %>
      </main>
    <% end %>
  </body>
</html>
