<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <title><%= content_for(:title) || "ErrSight — Sign in" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="icon" href="<%= asset_path("icon.png") %>" type="image/png">
    <link rel="icon" href="<%= asset_path("icon.svg") %>" type="image/svg+xml">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500;600;700&family=Geist:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "landing", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="landing-body grain" data-theme="light" data-density="comfortable">
    <%= render "shared/flash" %>
    <main class="auth-shell">
      <%= yield %>
    </main>
  </body>
</html>
