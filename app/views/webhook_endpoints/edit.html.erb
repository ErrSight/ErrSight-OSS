<% content_for :title, "Edit webhook endpoint — #{@project.name}" %>

<div class="page-head" style="padding-bottom: 14px;">
  <div>
    <div class="eyebrow"><span class="dot"></span><%= @project.name %></div>
    <h1 style="font-family: var(--sans); font-weight: 500; letter-spacing: -0.025em; font-size: 28px; line-height: 1.15; margin: 0;">Edit <em style="font-family: var(--serif); font-style: italic; color: var(--accent); font-weight: 400;">endpoint</em></h1>
  </div>
  <div>
    <%= link_to "← Back", project_webhook_endpoints_path(@project), class: "btn btn-ghost btn-sm" %>
  </div>
</div>

<section class="panel" style="max-width: 560px;">
  <div class="panel-head" style="padding: 10px 14px;">
    <span class="title"><%= @webhook_endpoint.url %></span>
  </div>
  <div style="padding: 16px;">
    <%= render "form", webhook_endpoint: @webhook_endpoint,
          url: project_webhook_endpoint_path(@project, @webhook_endpoint), method: :patch, submit_label: "Save changes" %>
  </div>
</section>
