<h1 style="margin:0 0 8px; font-size:22px; font-weight:600; color:#17161a; letter-spacing:-0.3px;">
  New ErrSight signup
</h1>
<p style="margin:0 0 24px; font-size:15px; line-height:1.6; color:#5b5a5f;">
  A new user just registered.
</p>

<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:#f6f5f1; border:1px solid #d9d7cf; border-radius:10px; margin:0 0 24px;">
  <tr>
    <td style="padding:18px 20px; font-size:14px; line-height:1.7; color:#17161a;">
      <strong>Email:</strong> <%= @user.email %><br>
      <strong>Name:</strong> <%= @user.name.presence || "(not provided)" %><br>
      <strong>Signup method:</strong> <%= @signup_method %><br>
      <strong>Signed up at:</strong> <%= @signup_time.strftime("%B %-d, %Y at %H:%M UTC") %>
    </td>
  </tr>
</table>

<% if @admin_url %>
  <table role="presentation" cellpadding="0" cellspacing="0" border="0">
    <tr>
      <td style="border-radius:8px; background:#ff5a3c;">
        <%= link_to "Open in admin", @admin_url, style: "display:inline-block; padding:12px 22px; color:#17161a; text-decoration:none; font-size:14px; font-weight:600; letter-spacing:0.2px; border-radius:8px;" %>
      </td>
    </tr>
  </table>
<% end %>

<p style="margin:24px 0 0; font-size:12px; color:#8f8d90;">
  Sent to <%= AdminNotificationMailer.recipient %> because <code>ADMIN_SIGNUP_NOTIFICATIONS</code> is set to <code>per_signup</code>.
</p>
