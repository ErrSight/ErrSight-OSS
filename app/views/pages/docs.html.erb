    <!-- ── Ruby / Rails ─────────────────────────────── -->
    <section class="docs-section" id="ruby">
      <div class="section-label">01 · Ruby / Rails</div>
      <div class="docs-section-head">
        <div class="docs-badge" style="color:#e0564c">Rb</div>
        <h2 class="docs-h2">Ruby on <em>Rails</em>.</h2>
      </div>

      <h3 class="docs-h3">Installation</h3>
      <p>Add to your <code class="inline">Gemfile</code>:</p>
      <%= render "pages/code_block", language: "ruby", code: 'gem "errsight"' %>
      <p>Then run:</p>
      <%= render "pages/code_block", language: "sh", code: "bundle install" %>

      <h3 class="docs-h3" id="ruby-config">Configuration</h3>
      <p>Create <code class="inline">config/initializers/errsight.rb</code>:</p>
      <%= render "pages/code_block", language: "ruby", code: <<~RUBY
        Errsight.configure do |config|
          config.api_key                = ENV["ERRSIGHT_API_KEY"]   # required
          config.environment            = Rails.env                  # "production", "staging", etc.
          config.host                   = ENV.fetch("ERRSIGHT_HOST", "https://errsight.com")
          # Verbose log forwarding in development; quiet in production.
          # In production, attach_to_rails_logger=true on a busy app
          # will generate a very high volume of events fast.
          config.attach_to_rails_logger = Rails.env.development?
          config.min_level              = Rails.env.development? ? :debug : :warning

          # Optional. Defaults shown:
          # config.batch_size     = 10            # events per HTTP request
          # config.flush_interval = 2             # background flush interval (seconds)
          # config.max_queue_size = 1000          # drop events when queue exceeds this
          # config.timeout        = 5             # HTTP open + read timeout (seconds)
          # config.enabled        = true          # set false to disable per environment
        end
      RUBY
      %>

      <div class="docs-note">
        <strong>What happens automatically (v0.1.3+):</strong>
        <ul>
          <li>Every unhandled Rails controller exception is captured with its full backtrace.</li>
          <li>Every <code class="inline">Rails.logger</code> call is forwarded (respecting <code class="inline">min_level</code>).</li>
          <li><strong>User context</strong> — <code class="inline">id</code>, <code class="inline">email</code>, <code class="inline">username</code> are pulled from the current Warden user (Devise, ActiveAdmin, any scope). <code class="inline">ip_address</code> comes from <code class="inline">request.remote_ip</code> even when no one is signed in.</li>
          <li><strong>Tags</strong> (filterable in the UI) — <code class="inline">controller</code>, <code class="inline">action</code>, <code class="inline">request_method</code>, <code class="inline">status</code>, <code class="inline">ruby_version</code>, <code class="inline">rails_version</code>, <code class="inline">hostname</code>.</li>
          <li><strong>Metadata</strong> — <code class="inline">path</code>, <code class="inline">full_path</code>, <code class="inline">format</code>, <code class="inline">duration</code>, <code class="inline">exception_class</code>, and filtered <code class="inline">params</code> (respects Rails' <code class="inline">filter_parameters</code>).</li>
        </ul>
      </div>

      <h3 class="docs-h3" id="ruby-manual">Manual logging</h3>
      <p>Use <code class="inline">Errsight.log</code> or <code class="inline">Errsight.capture_exception</code> anywhere in your app:</p>
      <%= render "pages/code_block", language: "ruby", code: <<~RUBY
        # Log at any level
        Errsight.log(level: :info,    message: "User signed up", metadata: { plan: "pro" })
        Errsight.log(level: :warning, message: "Slow query detected", metadata: { duration_ms: 850 })
        Errsight.log(level: :error,   message: "Payment gateway timeout")

        # Capture an exception object directly
        begin
          charge_card(user)
        rescue Stripe::CardError => e
          Errsight.capture_exception(e, metadata: { user_id: user.id, amount: 4900 })
          raise
        end
      RUBY
      %>

