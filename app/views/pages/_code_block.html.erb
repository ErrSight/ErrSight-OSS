<div class="doc-code-wrap" data-controller="copy">
  <button type="button"
          class="doc-code-copy"
          data-copy-target="button"
          data-action="click->copy#copy">copy</button>
  <span class="sr-only" role="status" aria-live="polite" data-copy-target="status"></span>
  <pre class="doc-code"><code data-copy-target="content"><%= code.strip %></code></pre>
</div>
