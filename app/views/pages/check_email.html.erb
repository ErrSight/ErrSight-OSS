<% content_for :title, "Check your email — ErrSight" %>

<div style="width: 100%; max-width: 420px; margin: 64px auto 0;">
  <section class="panel" style="padding: 32px 28px; text-align: center;">
    <div style="width: 48px; height: 48px; border-radius: 50%; background: var(--accent-soft); border: 1px solid var(--accent-line); display:flex; align-items:center; justify-content:center; margin: 0 auto 14px;" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
        <polyline points="22,6 12,13 2,6"/>
      </svg>
    </div>

    <h1 style="font-family: var(--sans); font-weight: 500; letter-spacing: -0.025em; font-size: 22px; margin: 0 0 8px; color: var(--fg);">Check your <em style="font-family: var(--serif); font-style: italic; color: var(--accent); font-weight: 400;">email</em></h1>
    <p style="margin: 0; font-size: 13.5px; color: var(--fg-dim); line-height: 1.55;">
      <% if @email.present? %>
        We sent a confirmation link to <strong style="color: var(--fg);"><%= @email %></strong>. Click it to activate your account.
      <% else %>
        We just sent you a confirmation link. Click it to activate your account.
      <% end %>
    </p>

    <p style="margin: 10px 0 0; font-family: var(--mono); font-size: 11.5px; color: var(--fg-dimmer);">
      Usually arrives within a minute. Check your spam if you don't see it.
    </p>

    <div style="margin-top: 20px; padding-top: 20px; border-top: 1px solid var(--line); display: grid; gap: 10px;">
      <p class="t-meta" style="margin: 0;">Didn't get it?</p>
      <%= form_with url: user_confirmation_path, method: :post, local: true, style: "display: grid; gap: 8px;" do %>
        <%= hidden_field_tag "user[email]", @email, autocomplete: "off" %>
        <% if @email.blank? %>
          <input type="email" name="user[email]" required autocomplete="email" placeholder="you@example.com"
            style="width:100%; background: var(--bg-3); border: 1px solid var(--line); color: var(--fg); border-radius: 8px; padding: 8px 12px; font-family: var(--sans); font-size: 13.5px;">
        <% end %>
        <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center; padding: 9px 14px;">
          Resend confirmation email
        </button>
      <% end %>

      <p style="margin: 4px 0 0; font-family: var(--mono); font-size: 11px; color: var(--fg-dimmer);">
        Wrong address?
        <% if public_signup_allowed? %>
          <%= link_to "Start over", new_user_registration_path, style: "color: var(--accent); text-decoration: none;" %>
          ·
        <% end %>
        <%= link_to "Sign in", new_user_session_path, style: "color: var(--accent); text-decoration: none;" %>
      </p>
    </div>
  </section>
</div>
