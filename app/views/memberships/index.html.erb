<% content_for :title, "Team members — #{@organization.name} — ErrSight" %>

<%
  role_tag = ->(role) {
    color = case role
            when "admin"  then "var(--accent)"
            when "member" then "var(--info)"
            when "viewer" then "var(--fg-dim)"
            else "var(--fg-dim)"
            end
    content_tag :span, role.capitalize, class: "tag",
      style: "background: color-mix(in oklab, #{color} 14%, transparent); color: #{color}; border: 1px solid color-mix(in oklab, #{color} 30%, transparent);"
  }
%>

<div class="page-head">
  <div>
    <div class="eyebrow">
      <span class="dot"></span>
      <%= @organization.name %>
    </div>
    <h1 class="page-title">Team <em>members</em></h1>
    <div class="page-sub">
      <span><span class="k"><%= @memberships.count %></span> member<%= 's' unless @memberships.count == 1 %></span>
    </div>
  </div>
  <div>
    <%= link_to "← Back to organization", organization_path(@organization), class: "btn btn-ghost btn-sm" %>
  </div>
</div>

<% if @current_membership&.admin? %>
  <section class="panel" id="invite-form">
    <div class="panel-head">
      <span class="title">Invite a teammate</span>
    </div>
    <div style="padding:18px;">
      <%= form_with url: organization_invitations_path(@organization) do |f| %>
        <div style="display:flex; flex-wrap:wrap; gap:12px; align-items:flex-end; max-width:760px;">
          <div style="flex:1 1 240px; min-width:220px;">
            <%= f.label :email, "Email", class: "t-eyebrow", style: "display:block; margin-bottom:8px;" %>
            <%= f.email_field :email, name: "invitation[email]",
                  placeholder: "teammate@example.com", required: true,
                  style: "width:100%; background: var(--bg-3); border: 1px solid var(--line); color: var(--fg); border-radius: 8px; padding: 9px 12px; font-family: var(--mono); font-size: 13px;" %>
          </div>
          <div style="flex:0 0 150px;">
            <%= f.label :role, "Role", class: "t-eyebrow", style: "display:block; margin-bottom:8px;" %>
            <%= f.select :role, [["Member", "member"], ["Viewer", "viewer"], ["Admin", "admin"]],
                  { selected: "member" },
                  { name: "invitation[role]",
                    style: "width:100%; background: var(--bg-3); border: 1px solid var(--line); color: var(--fg); border-radius: 8px; padding: 9px 12px; font-family: var(--sans); font-size: 13px;" } %>
          </div>
          <div style="flex:0 0 auto;">
            <%= f.submit "Send invite", class: "btn btn-primary" %>
          </div>
        </div>
      <% end %>
    </div>
  </section>
<% end %>

<% if @pending_invitations.any? %>
  <section class="panel" style="margin-top:22px;">
    <div class="panel-head">
      <span class="title">Pending invitations</span>
      <span class="right"><%= @pending_invitations.size %></span>
    </div>
    <div>
      <% @pending_invitations.each do |invitation| %>
        <div id="<%= dom_id(invitation) %>" style="display:flex; align-items:center; justify-content:space-between; padding: var(--row-pad) 18px; border-bottom: 1px solid var(--line);">
          <div>
            <div style="font-size:14px; font-weight:500; color: var(--fg);"><%= invitation.email %></div>
            <div class="t-meta" style="margin-top:2px;">
              <%= invitation.role.capitalize %> · expires in <%= time_ago_in_words(invitation.expires_at) %>
            </div>
          </div>
          <% if @current_membership&.admin? %>
            <%= button_to "Revoke", organization_invitation_path(@organization, invitation),
                  method: :delete,
                  class: "btn btn-ghost btn-sm",
                  style: "color: var(--err);",
                  data: { turbo_confirm: "Revoke invitation to #{invitation.email}?" } %>
          <% end %>
        </div>
      <% end %>
    </div>
  </section>
<% end %>

<section class="panel" style="margin-top:22px;">
  <div class="panel-head">
    <span class="title">Active members</span>
    <span class="right"><%= @memberships.count %></span>
  </div>
  <div>
    <% @memberships.each do |membership| %>
      <% user = membership.user %>
      <% initial = (user.name.presence || user.email).to_s[0].to_s.upcase %>
      <div id="<%= dom_id(membership) %>" style="display:flex; align-items:center; justify-content:space-between; padding: var(--row-pad) 18px; border-bottom: 1px solid var(--line); gap:16px;">
        <div style="display:flex; align-items:center; gap:12px; min-width:0;">
          <div style="width:36px; height:36px; border-radius: 50%; background: linear-gradient(135deg, var(--accent), oklch(55% 0.14 250)); color:#fff; font-family: var(--mono); font-weight:600; font-size:13px; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
            <%= initial %>
          </div>
          <div style="min-width:0;">
            <div style="font-size:14px; font-weight:500; color: var(--fg);">
              <%= user.name.presence || user.email %>
              <% if user == current_user %>
                <span class="t-meta" style="margin-left:4px;">(you)</span>
              <% end %>
            </div>
            <div class="t-meta" style="margin-top:2px;">
              <%= user.email %> · joined <%= membership.created_at.strftime("%b %d, %Y") %>
            </div>
          </div>
        </div>

        <div style="display:flex; align-items:center; gap:10px; flex-shrink:0;">
          <% is_owner_row = membership.organization.owner_id == user.id %>
          <% if @current_membership&.admin? && user != current_user && !is_owner_row %>
            <%= form_with model: membership, url: organization_membership_path(@organization, membership), method: :patch,
                  data: { controller: "auto-submit" },
                  style: "display:inline-flex; gap:8px; align-items:center;" do |f| %>
              <%= f.select :role, [["Admin", "admin"], ["Member", "member"], ["Viewer", "viewer"]],
                    { selected: membership.role },
                    { style: "background: var(--bg-3); border: 1px solid var(--line); color: var(--fg); border-radius: 6px; padding: 4px 8px; font-family: var(--mono); font-size: 11.5px;",
                      data: { action: "change->auto-submit#submit" } } %>
            <% end %>
            <%= button_to "Remove", organization_membership_path(@organization, membership),
                  method: :delete,
                  class: "btn btn-ghost btn-sm",
                  style: "color: var(--err); padding: 4px 8px;",
                  data: { turbo_confirm: "Remove #{user.name || user.email}?" } %>
          <% else %>
            <%= role_tag.call(membership.role) %>
            <% if is_owner_row %>
              <span class="tag" style="background: color-mix(in oklab, var(--accent) 14%, transparent); color: var(--accent); border: 1px solid color-mix(in oklab, var(--accent) 30%, transparent); margin-left: 4px;">Owner</span>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</section>
