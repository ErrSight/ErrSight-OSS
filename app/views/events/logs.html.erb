<% content_for :title, "Logs — #{@project.name} — ErrSight" %>

<div style="font-family: var(--mono); font-size: 11.5px; color: var(--fg-dim); display:flex; align-items:center; gap:10px; margin-bottom:14px;">
  <%= link_to @project.name, project_path(@project), style: "color: var(--fg-dim); text-decoration:none;" %>
  <span style="color: var(--fg-dimmer);">/</span>
  <span style="color: var(--fg);">Logs</span>
</div>

<div class="page-head">
  <div>
    <div class="eyebrow">
      <span class="dot"></span>
      Live stream
      <span class="kbd"><%= @project.name %>.log</span>
    </div>
    <h1 class="page-title">Log <em>viewer</em></h1>
    <div class="page-sub">
      <span><span class="k"><%= number_with_delimiter(@pagy.count) %></span> lines</span>
      <% if params[:q].present? %>
        <span>Matching <span class="k" style="color: var(--accent);">"<%= params[:q] %>"</span></span>
      <% end %>
      <span>Newest first</span>
    </div>
  </div>
  <div style="display:flex; gap:8px;">
    <%= link_to "Events", project_events_path(@project), class: "btn btn-ghost btn-sm" %>
    <%= link_to "Groups", groups_project_events_path(@project), class: "btn btn-ghost btn-sm" %>
  </div>
</div>

<!-- Filter bar -->
<div style="display:flex; flex-wrap:wrap; gap:10px; align-items:center; margin-bottom:14px;">
  <%= form_with url: logs_project_events_path(@project), method: :get,
        style: "flex:1; min-width:240px; display:flex; gap:8px;" do |f| %>
    <%= f.hidden_field :level,       value: params[:level] %>
    <%= f.hidden_field :environment, value: params[:environment] %>
    <div style="position:relative; flex:1;">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
           style="position:absolute; left:10px; top:50%; transform:translateY(-50%); color: var(--fg-dimmer); pointer-events:none;">
        <circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/>
      </svg>
      <%= f.text_field :q, value: params[:q],
            placeholder: "Filter logs…",
            autofocus: params[:q].present?,
            style: "width:100%; background: var(--bg-3); border: 1px solid var(--line); color: var(--fg); border-radius: 8px; padding: 8px 12px 8px 32px; font-family: var(--mono); font-size: 12px;" %>
    </div>
    <% if params[:q].present? %>
      <%= link_to "✕ clear", logs_project_events_path(@project, level: params[:level], environment: params[:environment]),
            class: "btn btn-ghost btn-sm" %>
    <% end %>
  <% end %>

  <div style="display:flex; gap:4px; font-family: var(--mono); font-size: 11px;">
    <% [
      ["ALL",   nil],
      ["DBG",   "debug"],
      ["INFO",  "info"],
      ["WARN",  "warning"],
      ["ERR",   "error"],
      ["FATAL", "fatal"],
    ].each do |label, value| %>
      <% active = params[:level].to_s == value.to_s %>
      <%= link_to label, logs_project_events_path(@project,
            level: value, environment: params[:environment], q: params[:q]),
            class: "lvl #{value}",
            style: "padding: 4px 8px; border-radius: 6px; text-decoration:none; font-size: 11px; #{'box-shadow: 0 0 0 1px var(--accent-line);' if active}" %>
    <% end %>
  </div>

  <% if @environments.size > 1 %>
    <%= form_with url: logs_project_events_path(@project), method: :get, data: { controller: "auto-submit" } do |f| %>
      <%= f.hidden_field :level, value: params[:level] %>
      <%= f.hidden_field :q,     value: params[:q] %>
      <%= f.select :environment,
            [["all envs", ""]] + @environments.map { |e| [e, e] },
            { selected: params[:environment] },
            style: "background: var(--bg-3); border: 1px solid var(--line); color: var(--fg); border-radius: 8px; padding: 6px 10px; font-family: var(--mono); font-size: 11.5px;",
            data: { action: "change->auto-submit#submit" } %>
    <% end %>
  <% end %>
</div>

<section class="panel"
     data-controller="live-logs"
     data-live-logs-project-id-value="<%= @project.id %>"
     data-live-logs-filter-level-value="<%= params[:level] %>"
     data-live-logs-filter-env-value="<%= params[:environment] %>"
     data-live-logs-filter-q-value="<%= params[:q] %>">
  <div class="panel-head">
    <span class="title"><%= @project.name %>.log</span>
    <span class="right">
      <span>Newest first</span>
      <button type="button"
              data-live-logs-target="toggleBtn"
              data-action="live-logs#togglePause"
              style="display:inline-flex; align-items:center; gap:6px; padding: 3px 10px; border-radius: 999px; border: 1px solid var(--line); background: var(--bg-3); font-family: var(--mono); font-size: 10.5px; color: var(--fg-dim); cursor:pointer;">
        <span data-live-logs-target="statusDot"
              style="width:6px; height:6px; border-radius:50%; background: var(--ok); animation: pulse 1.8s infinite ease-in-out;"></span>
        <span data-live-logs-target="statusLabel" style="color: var(--ok); letter-spacing: 0.04em;">LIVE</span>
      </button>
    </span>
  </div>

  <% if @events.empty? %>
    <div class="panel-empty">
      <div class="t">
        <% if params[:q].present? || params[:level].present? %>
          No lines match your filter.
        <% else %>
          No log entries yet.
        <% end %>
      </div>
      <div class="d">Lines stream in here the moment your app logs them.</div>
    </div>
  <% else %>
    <div id="logs-list" data-live-logs-target="logsList">
      <%= render "events/log_rows", events: @events, pagy: @pagy %>
    </div>
  <% end %>
</section>
