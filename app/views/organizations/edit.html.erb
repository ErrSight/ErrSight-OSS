<% content_for :title, "#{@organization.name} settings — ErrSight" %>

<%
  field_style = "width:100%; background: var(--bg-3); border: 1px solid var(--line); color: var(--fg); border-radius: 8px; padding: 8px 12px; font-family: var(--sans); font-size: 13.5px;"
%>

<div class="page-head" style="padding-bottom: 14px;">
  <div>
    <div class="eyebrow"><span class="dot"></span><%= @organization.name %></div>
    <h1 style="font-family: var(--sans); font-weight: 500; letter-spacing: -0.025em; font-size: 28px; line-height: 1.15; margin: 0;">Organization <em style="font-family: var(--serif); font-style: italic; color: var(--accent); font-weight: 400;">settings</em></h1>
  </div>
  <div>
    <%= link_to "← Back", organization_path(@organization), class: "btn btn-ghost btn-sm" %>
  </div>
</div>

<div style="display:grid; gap: 14px; max-width: 560px;">
  <section class="panel">
    <div class="panel-head" style="padding: 10px 14px;">
      <span class="title">General</span>
    </div>
    <div style="padding: 16px;">
      <%= form_with model: @organization do |f| %>
        <% if @organization.errors.any? %>
          <div style="border: 1px solid color-mix(in oklab, var(--err) 30%, transparent); background: color-mix(in oklab, var(--err) 10%, transparent); color: var(--err); border-radius: 10px; padding: 10px 14px; font-size: 13px; margin-bottom: 16px;">
            <p style="margin:0 0 6px; font-weight: 500;"><%= pluralize(@organization.errors.count, "error") %>:</p>
            <ul style="margin:0; padding-left: 18px;">
              <% @organization.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div>
          <%= f.label :name, "Organization name", class: "t-eyebrow", style: "display:block; margin-bottom:6px;" %>
          <%= f.text_field :name, style: field_style %>
        </div>

        <div style="display:flex; gap:10px; margin-top: 18px;">
          <%= f.submit "Save changes", class: "btn btn-primary btn-sm" %>
          <%= link_to "Cancel", organization_path(@organization), class: "btn btn-ghost btn-sm" %>
        </div>
      <% end %>
    </div>
  </section>
</div>
