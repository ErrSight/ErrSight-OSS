<% content_for :title, "Invitation expired — ErrSight" %>

<div style="width: 100%; max-width: 420px; margin: 0 auto;">
  <section class="panel" style="padding: 40px 32px; text-align: center;">
    <div style="width: 52px; height: 52px; border-radius: 50%; background: color-mix(in oklab, var(--warn) 14%, transparent); border: 1px solid color-mix(in oklab, var(--warn) 30%, transparent); display:flex; align-items:center; justify-content:center; margin: 0 auto 16px;">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--warn)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
      </svg>
    </div>

    <h1 style="font-family: var(--sans); font-weight: 500; letter-spacing: -0.025em; font-size: 22px; margin: 0 0 8px; color: var(--fg);">Invitation <em style="font-family: var(--serif); font-style: italic; color: var(--accent); font-weight: 400;">expired</em></h1>
    <p style="margin: 0 0 20px; font-size: 13.5px; color: var(--fg-dim); line-height: 1.55;">
      This invitation is no longer valid. Ask the organization admin to send a new one.
    </p>

    <%= link_to "Go to homepage", root_path, class: "btn btn-primary btn-sm" %>
  </section>
</div>
