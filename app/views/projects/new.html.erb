<% content_for :title, "New project — ErrSight" %>

<div class="page-head" style="padding-bottom: 14px;">
  <div>
    <div class="eyebrow"><span class="dot"></span>New</div>
    <h1 style="font-family: var(--sans); font-weight: 500; letter-spacing: -0.025em; font-size: 28px; line-height: 1.15; margin: 0;">Create a <em style="font-family: var(--serif); font-style: italic; color: var(--accent); font-weight: 400;">project</em></h1>
  </div>
  <div>
    <%= link_to "← All projects", projects_path, class: "btn btn-ghost btn-sm" %>
  </div>
</div>

<section class="panel" style="max-width: 560px;">
  <div class="panel-head" style="padding: 10px 14px;">
    <span class="title">Project details</span>
  </div>
  <div style="padding: 16px;">
    <%= render "form", project: @project %>
  </div>
</section>
