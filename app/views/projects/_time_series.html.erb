<%
  fingerprint ||= nil
  environment ||= nil
  title       ||= "Events over time"
%>
<section class="panel" style="margin-top:22px; padding:18px;"
     data-controller="time-series-chart"
     data-time-series-chart-url-value="<%= time_series_project_path(project) %>"
     data-time-series-chart-range-value="24h"
     <% if fingerprint %>data-time-series-chart-fingerprint-value="<%= fingerprint %>"<% end %>
     <% if environment %>data-time-series-chart-environment-value="<%= environment %>"<% end %>>
  <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:14px; gap:12px;">
    <div>
      <div class="t-eyebrow"><%= title %></div>
      <div class="t-meta" style="margin-top:4px;"><span data-time-series-chart-target="total">0</span> events in range</div>
    </div>
    <div style="display:flex; align-items:center; gap:12px;">
      <span data-time-series-chart-target="loading" class="t-meta" style="display:none;">Loading…</span>
      <select data-time-series-chart-target="rangeSelect"
              data-action="change->time-series-chart#selectRange"
              style="background: var(--bg-3); border: 1px solid var(--line); color: var(--fg); border-radius: 6px; padding: 4px 8px; font-family: var(--mono); font-size: 11.5px;">
        <option value="24h">Last 24 hours</option>
        <option value="7d">Last 7 days</option>
        <option value="30d">Last 30 days</option>
      </select>
    </div>
  </div>
  <div data-time-series-chart-target="canvas" style="width:100%;"></div>
  <p data-time-series-chart-target="empty" class="t-small" style="display:none; margin:8px 0 0;">No events in this range.</p>
</section>
