<% content_for :title, "Erase user data — #{@project.name}" %>

<div style="font-family: var(--mono); font-size: 11.5px; color: var(--fg-dim); display:flex; align-items:center; gap: 10px; margin-bottom: 14px;">
  <%= link_to @project.name, project_path(@project), style: "color: var(--fg-dim); text-decoration:none;" %>
  <span style="color: var(--fg-dimmer);">/</span>
  <span style="color: var(--fg);">Erase user data</span>
</div>

<div class="page-head" style="padding-bottom: 14px;">
  <div>
    <div class="eyebrow"><span class="dot" style="background: var(--err); box-shadow: 0 0 8px color-mix(in oklab, var(--err) 60%, transparent);"></span>GDPR · irreversible</div>
    <h1 style="font-family: var(--sans); font-weight: 500; letter-spacing: -0.025em; font-size: 28px; line-height: 1.15; margin: 0;">Erase <em style="font-family: var(--serif); font-style: italic; color: var(--accent); font-weight: 400;">user</em> data</h1>
    <p style="margin: 6px 0 0; font-size: 13.5px; color: var(--fg-dim); line-height: 1.55;">
      Permanently deletes every event tagged with the given user identifier. This is <strong style="color: var(--fg);">irreversible</strong>.
    </p>
  </div>
</div>

<section class="panel" style="max-width: 560px;">
  <div class="panel-head" style="padding: 10px 14px;">
    <span class="title">Identifier</span>
  </div>
  <div style="padding: 16px;">
    <%= form_with url: project_data_erasure_path(@project), method: :post, local: true do |f| %>
      <div>
        <%= label_tag :user_identifier, "User identifier", class: "t-eyebrow", style: "display:block; margin-bottom:6px;" %>
        <%= text_field_tag :user_identifier, params[:user_identifier],
              required: true,
              placeholder: "e.g. 42, user@example.com, alice",
              style: "width:100%; background: var(--bg-3); border: 1px solid var(--line); color: var(--fg); border-radius: 8px; padding: 8px 12px; font-family: var(--mono); font-size: 12.5px;" %>
        <p style="margin: 6px 0 0; font-size: 11.5px; color: var(--fg-dim); font-family: var(--mono);">
          Matches the <code>user_identifier</code> column (id / email / username, whichever was reported).
        </p>
      </div>
      <div style="display:flex; align-items:center; gap: 10px; margin-top: 18px;">
        <%= f.submit "Erase matching events",
              data: { turbo_confirm: "Permanently delete every matching event? This cannot be undone." },
              style: "background: var(--err); color: #fff; border: 0; border-radius: 8px; padding: 7px 12px; font-family: var(--sans); font-size: 12.5px; font-weight: 500; cursor: pointer;" %>
        <%= link_to "Cancel", project_path(@project), class: "btn btn-ghost btn-sm" %>
      </div>
    <% end %>
  </div>
</section>
