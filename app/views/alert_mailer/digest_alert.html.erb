<h1 style="margin:0 0 8px; font-size:22px; font-weight:600; color:#17161a; letter-spacing:-0.3px;">
  <%= @events.count %> new <%= 'error'.pluralize(@events.count) %> in
  <span style="font-family: Georgia, 'Times New Roman', serif; font-style: italic; color:#ff5a3c; font-weight:400;"><%= @project.name %></span>
</h1>
<p style="margin:0 0 24px; font-size:14px; color:#5b5a5f;">
  Grouped over the last <%= @period %>.
</p>

<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="border-collapse:collapse; margin:0 0 24px;">
  <thead>
    <tr>
      <th align="left" style="padding:10px 8px; border-bottom:1px solid #d9d7cf; font-size:11px; text-transform:uppercase; letter-spacing:0.6px; color:#8f8d90; font-weight:600;">Level</th>
      <th align="left" style="padding:10px 8px; border-bottom:1px solid #d9d7cf; font-size:11px; text-transform:uppercase; letter-spacing:0.6px; color:#8f8d90; font-weight:600;">Message</th>
      <th align="right" style="padding:10px 8px; border-bottom:1px solid #d9d7cf; font-size:11px; text-transform:uppercase; letter-spacing:0.6px; color:#8f8d90; font-weight:600;">Time</th>
    </tr>
  </thead>
  <tbody>
    <% @events.first(20).each do |event| %>
      <% pill = event.fatal? ? "#ff5a3c" : (event.error? ? "#ff5a3c" : "#c79528") %>
      <tr>
        <td valign="top" style="padding:12px 8px; border-bottom:1px solid #ecebe6;">
          <span style="display:inline-block; padding:2px 8px; background:<%= pill %>; color:#17161a; font-size:10px; font-weight:700; letter-spacing:0.5px; text-transform:uppercase; border-radius:999px;"><%= event.level %></span>
        </td>
        <td valign="top" style="padding:12px 8px; border-bottom:1px solid #ecebe6; font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; font-size:12px; color:#17161a; word-break:break-word;">
          <%= event.message.truncate(100) %>
        </td>
        <td valign="top" align="right" style="padding:12px 8px; border-bottom:1px solid #ecebe6; font-size:12px; color:#5b5a5f; white-space:nowrap;">
          <%= event.occurred_at.strftime("%H:%M") %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<% if @events.count > 20 %>
  <p style="margin:0 0 20px; font-size:13px; color:#5b5a5f;">… and <%= @events.count - 20 %> more.</p>
<% end %>

<table role="presentation" cellpadding="0" cellspacing="0" border="0">
  <tr>
    <td style="border-radius:8px; background:#17161a;">
      <%= link_to "View all events", @project_url, style: "display:inline-block; padding:12px 22px; color:#f6f5f1; text-decoration:none; font-size:14px; font-weight:600; letter-spacing:0.2px; border-radius:8px;" %>
    </td>
  </tr>
</table>

<p style="margin:28px 0 0; font-size:12px; color:#8f8d90;">
  You're receiving this digest because you have hourly alerts enabled for <%= @project.name %>.
</p>
