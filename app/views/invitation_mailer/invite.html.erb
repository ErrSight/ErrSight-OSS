<h1 style="margin:0 0 8px; font-size:22px; font-weight:600; color:#17161a; letter-spacing:-0.3px;">
  You're invited to
  <span style="font-family: Georgia, 'Times New Roman', serif; font-style: italic; color:#ff5a3c; font-weight:400;"><%= @organization.name %></span>
</h1>
<p style="margin:0 0 24px; font-size:15px; line-height:1.6; color:#5b5a5f;">
  <strong style="color:#17161a;"><%= @inviter.name || @inviter.email %></strong> invited you to join
  <strong style="color:#17161a;"><%= @organization.name %></strong> on ErrSight as
  <strong style="color:#17161a;"><%= @invitation.role.capitalize %></strong>.
</p>

<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:#f6f5f1; border:1px solid #d9d7cf; border-radius:10px; margin:0 0 24px;">
  <tr>
    <td style="padding:18px 20px; font-size:14px; line-height:1.6; color:#5b5a5f;">
      ErrSight captures every exception and log line the instant it happens — grouped, fingerprinted, and attributed to the user who hit it. Accept the invite to start seeing errors from <%= @organization.name %>'s projects.
    </td>
  </tr>
</table>

<table role="presentation" cellpadding="0" cellspacing="0" border="0">
  <tr>
    <td style="border-radius:8px; background:#ff5a3c;">
      <%= link_to "Accept invitation", @accept_url, style: "display:inline-block; padding:12px 22px; color:#17161a; text-decoration:none; font-size:14px; font-weight:600; letter-spacing:0.2px; border-radius:8px;" %>
    </td>
  </tr>
</table>

<p style="margin:24px 0 0; font-size:13px; color:#5b5a5f;">
  This invitation expires on <strong style="color:#17161a;"><%= @invitation.expires_at.strftime("%B %-d, %Y") %></strong>.
</p>

<p style="margin:16px 0 0; font-size:12px; color:#8f8d90;">
  If you didn't expect this invitation, you can safely ignore this email.
</p>
